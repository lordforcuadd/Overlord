{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "allow-powershell",
  "description": "Permitir a Overlord ejecutar scripts de optimización",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell",
          "args": ["-ExecutionPolicy", "Bypass", "-NoProfile", "-File", "*"]
        }
      ]
    }
  ]
}
